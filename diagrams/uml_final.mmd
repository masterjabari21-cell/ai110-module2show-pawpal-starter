classDiagram
    %% Final UML — matches pawpal_system.py implementation

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +str description
        +str frequency
        +bool completed
        +date due_date
        +str start_time
        +is_high_priority() bool
        +mark_complete() None
        +reset() None
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~str~ special_needs
        +list~Task~ tasks
        +add_task(task) None
        +list_tasks() list~Task~
        +pending_tasks() list~Task~
        +completed_tasks() list~Task~
    }

    class Owner {
        +str name
        +int available_minutes
        +list~str~ preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +list_pets() list~Pet~
        +get_all_tasks() list~Task~
        +set_available_time(minutes) None
    }

    class Scheduler {
        +Owner owner
        +int start_hour
        -_get_all_pending() list
        +sort_by_priority(pairs) list
        +sort_by_time(tasks) list~Task~
        +filter_by_time(pairs) list
        +filter_tasks(pet_name, completed) list
        +build_plan() list
        +detect_conflicts(plan) list~str~
        +reschedule_recurring(task, pet) Task
        +mark_complete(task) None
        +reset_all() None
        +explain_plan(plan) str
    }

    Owner "1" o-- "0..*" Pet : owns
    Pet "1" o-- "0..*" Task : has
    Scheduler --> Owner : reads pets & time budget
    Scheduler ..> Task : sorts, filters, reschedules
    Scheduler ..> Pet : adds recurring copies to
